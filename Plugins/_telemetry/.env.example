# Olytic Telemetry Configuration
#
# This file shows what environment variables are needed for telemetry.
# The actual .env file (with real credentials) should be stored in:
#   ~/Olytic Setup/.env
#
# Do NOT commit the actual .env file to git. This file (.env.example)
# serves as a template only and contains placeholder values.

# Supabase Project URL
# Example: https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase API Key (Service Role or Anon key)
# This should be a long string like: sb_...
SUPABASE_API_KEY=sb_your_api_key_here
